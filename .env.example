# Netlify Configuration
# Get these from your Netlify site settings (Team Settings > Authentication tokens)
MY_SITE_ID=your_netlify_site_id_here
MY_NETLIFY_TOKEN=your_netlify_personal_access_token_here

# Claude API
# Get this from https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# Mailgun Configuration (optional, for webhook verification)
# Get this from your Mailgun account
MAILGUN_WEBHOOK_KEY=your_mailgun_webhook_key_here
